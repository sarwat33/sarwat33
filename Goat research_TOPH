#include <stdio.h>
#include <string.h>
int main()
{
    int test,i,j,max,space,temp_count;
    max=0;
    char str[20][20];
    scanf("%d",&test);
    for(i=0;i<test;i++)
    {
        scanf("%s",&str[i]);
    }
    // max length of string //
    for(i=0;i<test;i++)
    {
        if(strlen(str[i])>max)
        {
            max = strlen(str[i]);
        }
    }
    if(max%2==1)
    {
        temp_count=1;
    }
    else if(max%2==0)
    {
        temp_count=0;
    }
    // val = 1 ; unchanged max string //
    if(temp_count=1)
    {

    for(i=0;i<test;i++)
    {
        // when removing a  becomes 0 //
        if(strlen(str[i])==2)
        {
            for(space=0;space<(max-strlen(str[i])-1)/2;space++)
            {
                printf(" ");
            }
            printf("%s",str[i]);
            printf("a\n");
        }
        // when a= even //
        else if(strlen(str[i])%2==1)
        {
            for(space=0;space<(max-strlen(str[i]))/2;space++)
            {
                printf(" ");
            }
            printf("%s\n",str[i]);
        }
        else if(strlen(str[i])%2==0)
        {
           for(space=0;space<(max-strlen(str[i])+1)/2;space++)
            {
                printf(" ");
            }
            for(j=0;j<strlen(str[i])-1;j++)
            {
                printf("%c",str[i][j]);
            }
            printf("\n");
        }
    }

    }
    else if(temp_count=0)
    {
        // when removing a  becomes 0 //
        if(strlen(str[i])==2)
        {
            for(space=0;space<(max-1-strlen(str[i])+1)/2;space++)
            {
                printf(" ");
            }
            printf("%s",str[i]);
            printf("a\n");
        }
        // when a= even //
        else if(strlen(str[i])%2==1)
        {
            for(space=0;space<(max-1-strlen(str[i]))/2;space++)
            {
                printf(" ");
            }
            printf("%s\n",str[i]);
        }
        else if(strlen(str[i])%2==0)
        {
           for(space=0;space<(max-1-strlen(str[i])-1)/2;space++)
            {
                printf(" ");
            }
            for(j=0;j<strlen(str[i])-1;j++)
            {
                printf("%c",str[i][j]);
            }
            printf("\n");
        }
    }
    return 0;

}
